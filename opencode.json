{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",
  "share": "manual",
  "autoupdate": true,
  "instructions": [
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "webfetch": "allow"
  },
  "mcp": {
    "tradingview": {
      "type": "stdio",
      "command": "node",
      "args": [
        "./tradingview-mcp/src/server.js"
      ],
      "env": {},
      "enabled": true,
      "platform_overrides": {
        "wsl": {
          "$comment": "On WSL Ubuntu, TV Desktop runs on Windows native. wsl_tv_bridge.sh exec's node.exe against the Windows-side clone via /mnt/c/. Requires TV_MCP_WIN_REPO env in $REPO/.env (e.g. C:\\Users\\jose\\wally-trader).",
          "command": "bash",
          "args": [
            "adapters/hermes/wsl_tv_bridge.sh"
          ]
        }
      }
    },
    "wally": {
      "type": "stdio",
      "command": "shared/wally_core/.venv/bin/python",
      "args": [
        "-m",
        "wally_trader_mcp"
      ],
      "env": {},
      "enabled": true
    },
    "notion": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      },
      "enabled": true
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "scripts/ml_system/data/**",
      "scripts/ml_system/supervised/model/**",
      "/tmp/**",
      ".opencode/**",
      ".claude/cache/**",
      ".claude/watcher/**"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
